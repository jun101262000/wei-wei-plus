<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>葳葳海鮮 - 訂購系統</title>
    
    <!-- 替換為最穩定快速的 cdnjs 來源 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.6/babel.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    
    <!-- 引入穩定的 QR Code 生成與解析套件 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap');
        body { 
            font-family: 'Noto Sans TC', sans-serif; 
            font-size: 16px; /* 基礎字體縮小以適應手機，依賴 Tailwind 的 text- 類別放大 */
            line-height: 1.4;
            -webkit-text-size-adjust: 100%;
            padding-bottom: 240px;
        }
        .order-table th { padding: 12px 8px; border-bottom: 3px solid #000; color: #000; }
        .order-table td { padding: 16px 8px; border-bottom: 1px solid #cbd5e1; color: #000; }
        
        input:focus { border-color: #0369a1 !important; outline: none; }
        
        .modal-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.85); z-index: 9999;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            padding: 20px;
        }

        .history-drawer { transition: transform 0.3s ease-in-out; }
        .drawer-transition { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        
        .footer-input {
            background-color: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
        }
        .footer-input:focus {
            background-color: rgba(255,255,255,0.2);
            border-color: white;
        }
        .footer-input::placeholder { color: rgba(255,255,255,0.4); }

        /* 熱感應貼紙專用樣式 (100mm x 150mm) 保持絕對固定尺寸確保列印品質 */
        #thermal-receipt {
            position: absolute;
            left: -9999px;
            top: 0;
            width: 800px;
            min-height: 1200px;
            background: #ffffff;
            color: #000000;
            padding: 40px;
            box-sizing: border-box;
            font-family: 'Noto Sans TC', sans-serif;
            border: 4px solid #000000;
            -webkit-font-smoothing: none;
            text-rendering: optimizeSpeed;
        }
        .thermal-header { text-align: center; border-bottom: 6px solid #000; padding-bottom: 20px; margin-bottom: 20px; }
        .thermal-title { font-size: 64px; font-weight: 900; line-height: 1; color: #000; }
        .thermal-meta { font-size: 26px; margin-top: 10px; font-weight: 900; color: #000; }
        
        .thermal-info { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; border-bottom: 4px solid #000; padding-bottom: 20px; }
        .thermal-customer { font-size: 46px; font-weight: 900; color: #000; word-break: break-all; }
        .thermal-phone { font-size: 34px; font-weight: 900; color: #000; margin-top: 5px; }
        .thermal-address { font-size: 30px; font-weight: 900; color: #000; margin-top: 10px; line-height: 1.3; }
        .thermal-status { font-size: 32px; font-weight: 900; border: 4px solid #000; padding: 5px 15px; border-radius: 10px; display: inline-block; margin-top: 10px; color: #000; }

        .thermal-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        .thermal-table th { border-bottom: 4px solid #000; text-align: left; font-size: 30px; padding: 10px 0; color: #000; font-weight: 900; }
        .thermal-table td { border-bottom: 2px dashed #000; font-size: 48px; padding: 15px 0; font-weight: 400; color: #000; } 
        
        .thermal-footer { border-top: 6px solid #000; padding-top: 20px; }
        .thermal-total-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 10px; }
        .thermal-total-label { font-size: 34px; font-weight: 900; color: #000; }
        .thermal-total-amount { font-size: 80px; font-weight: 900; line-height: 1; color: #000; }
        
        .thermal-contact { 
            text-align: left; 
            margin-top: 30px; 
            color: #000; 
            border-top: 4px solid #000; 
            padding-top: 20px;
        }

        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        @media print {
            .no-print { display: none !important; }
            body { background: white; padding-bottom: 0; }
            .print-container { width: 100%; border: none; box-shadow: none; }
            tr.even-row { background-color: #f1f5f9 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body class="bg-gray-100">
    <div id="root">
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; color: #475569;">
            <svg style="animation: spin 1s linear infinite; width: 50px; height: 50px; margin-bottom: 20px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" stroke-opacity="0.25"></circle>
                <path fill="#0284c7" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <h2 style="font-size: 20px; font-weight: bold; margin-bottom: 10px;">系統載入中...</h2>
            <p style="font-size: 14px;">首次開啟需載入核心元件，請稍候。</p>
        </div>
    </div>

    <script type="text/babel">
        const { useState, useMemo, useEffect } = React;

        const Icons = {
            Anchor: () => <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" className="w-8 h-8 md:w-10 md:h-10"><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><circle cx="12" cy="5" r="3"/></svg>,
            Plus: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>,
            Trash: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>,
            Camera: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="w-6 h-6 md:w-7 md:h-7"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>,
            Printer: () => <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>,
            Close: () => <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="w-8 h-8"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>,
            History: () => <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5 md:w-6 md:h-6"><path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/></svg>,
            Refresh: () => <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5 md:w-6 md:h-6"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>,
            List: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>,
            ChevronLeft: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m15 18-6-6 6-6"/></svg>,
            Alert: () => <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>,
            Check: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5 md:w-6 md:h-6"><polyline points="20 6 9 17 4 12"/></svg>,
            CheckCircle: () => <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>,
            CreditCard: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5 md:w-6 md:h-6"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/><line x1="10" x2="10" y1="15" y2="15"/></svg>,
            Receipt: () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="w-6 h-6 md:w-7 md:h-7"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1z"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 17V7"/></svg>,
            Dollar: () => <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5 md:w-6 md:h-6"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>,
            Upload: () => <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5 md:w-6 md:h-6"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        };

        const PRODUCTS_LIST = [
            { id: 1, name: '整尾無刺虱目魚', unit: '尾', defPrice: 220, range: '170~220', canEdit: true, defJinPrice: 190 },
            { id: 2, name: '去頭尾半尾魚', unit: '片', defPrice: 170, range: '110~170', canEdit: true, defJinPrice: 240 },
            { id: 3, name: '透抽', unit: '尾', defPrice: 330, range: '180~330', canEdit: true, note: '依重量', defJinPrice: 330 },
            { id: 4, name: '魚肚', unit: '片(200~240g)', defPrice: 130, canEdit: true },
            { id: 5, name: '魚柳', unit: '包(半斤)', defPrice: 70, canEdit: true },
            { id: 6, name: '魚嶺(已調味)', unit: '包(半斤)', defPrice: 110, canEdit: true },
            { id: 7, name: '魚皮', unit: '包(半斤)', defPrice: 70, canEdit: true },
            { id: 8, name: '生蝦', unit: '包(500g)', defPrice: 270, canEdit: true },
            { id: 9, name: '熟蝦(退冰即可食)', unit: '包(500g)', defPrice: 270, canEdit: true },
            { id: 10, name: '蝦仁', unit: '包(150g)', defPrice: 120, canEdit: true },
            { id: 11, name: '挪威鯖魚(微刺)', unit: '片', defPrice: 80, canEdit: true },
            { id: 12, name: '吳郭魚(台灣鯛)', unit: '大尾', defPrice: 100, range: '80~100', canEdit: true },
            { id: 13, name: '學甲虱目魚丸(真空包)', unit: '包(1斤)', defPrice: 120, canEdit: true, defJinPrice: 120 },
            { id: 14, name: '花枝丸', unit: '包(1斤)', defPrice: 300, canEdit: true, defJinPrice: 300 },
            { id: 15, name: '花枝月亮蝦餅', unit: '包', defPrice: 360, canEdit: true },
            { id: 16, name: '花枝蝦排', unit: '包', defPrice: 360, canEdit: true },
        ];

        const minifyData = (d) => {
            const q = {}; const pr = {}; const jp = {};
            for (const p of PRODUCTS_LIST) {
                const qty = parseInt(d.stdQtys[p.id]) || 0;
                if (qty > 0) q[p.id] = qty;
                if (d.stdPrices[p.id] !== p.defPrice) pr[p.id] = d.stdPrices[p.id];
                if (p.defJinPrice && d.jinPrices[p.id] !== p.defJinPrice) jp[p.id] = d.jinPrices[p.id];
            }
            return { o: d.orderer, ps: d.paymentStatus, ca: d.creditAmount, q, pr, jp, l: d.limitedItems, sh: d.sharingItems, s: d.ship, dc: d.discount };
        };

        const restoreData = (m) => {
            const defaultPrices = PRODUCTS_LIST.reduce((a,p)=>({...a,[p.id]:p.defPrice}), {});
            const defaultJinPrices = PRODUCTS_LIST.reduce((a,p)=>p.defJinPrice ? {...a,[p.id]:p.defJinPrice} : a, {});
            if (m.pr) for (const key in m.pr) defaultPrices[key] = m.pr[key];
            if (m.jp) for (const key in m.jp) defaultJinPrices[key] = m.jp[key];

            return {
                orderer: m.o || { name: '', phone: '', address: '', isHandwritten: false },
                paymentStatus: m.ps || 'pending', creditAmount: m.ca || '',
                stdQtys: m.q || {}, stdPrices: defaultPrices, jinPrices: defaultJinPrices,
                limitedItems: m.l || [], sharingItems: m.sh || [],
                ship: m.s || { type: 'free', fee: '' }, discount: m.dc || ''
            };
        };

        function App() {
            const [showPriceModal, setShowPriceModal] = useState(true);
            const [sysMsg, setSysMsg] = useState(null);

            const [orderer, setOrderer] = useState({ name: '', phone: '', address: '', isHandwritten: false });
            const [paymentStatus, setPaymentStatus] = useState('pending');
            const [creditAmount, setCreditAmount] = useState('');
            const [stdQtys, setStdQtys] = useState({});
            const [stdPrices, setStdPrices] = useState(PRODUCTS_LIST.reduce((a,p)=>({...a,[p.id]:p.defPrice}), {}));
            const [jinPrices, setJinPrices] = useState(PRODUCTS_LIST.reduce((a,p)=>p.defJinPrice ? {...a,[p.id]:p.defJinPrice} : a, {}));
            
            const [limitedItems, setLimitedItems] = useState([]);
            const [newLimited, setNewLimited] = useState({ name: '', price: '', qty: '' });
            const [sharingItems, setSharingItems] = useState([]);
            const [newSharing, setNewSharing] = useState({ name: '', qty: '' });
            const [ship, setShip] = useState({ type: 'free', fee: '' });
            const [discount, setDiscount] = useState('');
            
            const [showBill, setShowBill] = useState(false);
            const [screenshotUrl, setScreenshotUrl] = useState(null);
            const [history, setHistory] = useState([]);
            const [showHistory, setShowHistory] = useState(false);
            const [showDetailDrawer, setShowDetailDrawer] = useState(false);
            const [currentOrderId, setCurrentOrderId] = useState(null);
            const [confirmAction, setConfirmAction] = useState(null); 
            
            const [qrSrc, setQrSrc] = useState(''); 
            const [priceListQrSrc, setPriceListQrSrc] = useState(''); 
            const [isGeneratingPrice, setIsGeneratingPrice] = useState(false);

            useEffect(() => {
                const saved = localStorage.getItem('weiwei_history_v2');
                if (saved) {
                    try { setHistory(JSON.parse(saved)); } catch(e) {}
                }
            }, []);

            const clearAllState = () => {
                setOrderer({ name: '', phone: '', address: '', isHandwritten: false });
                setPaymentStatus('pending'); setCreditAmount('');
                setStdQtys({}); setLimitedItems([]); setSharingItems([]);
                setShip({ type: 'free', fee: '' }); setDiscount('');
                setNewLimited({ name: '', price: '', qty: '' }); setNewSharing({ name: '', qty: '' });
                setCurrentOrderId(null); setShowBill(false); setScreenshotUrl(null); setQrSrc('');
                window.scrollTo(0, 0); setConfirmAction(null);
            };

            const saveToHistory = (orderData) => {
                const newRecord = {
                    id: currentOrderId || Date.now(),
                    timestamp: new Date().toLocaleString('zh-TW'),
                    data: { ...orderData, grandTotal: summary.grandTotal }
                };
                let newHistory = [...history];
                if (currentOrderId) {
                    const idx = newHistory.findIndex(h => h.id === currentOrderId);
                    if (idx >= 0) newHistory[idx] = newRecord; else newHistory.unshift(newRecord);
                } else { newHistory.unshift(newRecord); }
                if (newHistory.length > 20) newHistory = newHistory.slice(0, 20);
                setHistory(newHistory);
                localStorage.setItem('weiwei_history_v2', JSON.stringify(newHistory));
                return newRecord.id;
            };

            const loadFromHistory = (record) => {
                const d = record.data;
                setOrderer({
                    name: d.orderer?.name || '', phone: d.orderer?.phone || '',
                    address: d.orderer?.address || '', isHandwritten: d.orderer?.isHandwritten || false
                });
                setPaymentStatus(d.paymentStatus || 'pending'); setCreditAmount(d.creditAmount || '');
                setStdQtys(d.stdQtys); setStdPrices(d.stdPrices); 
                if(d.jinPrices) setJinPrices(d.jinPrices);
                setLimitedItems(d.limitedItems || []); setSharingItems(d.sharingItems || []);
                setShip(d.ship); setDiscount(d.discount);
                setCurrentOrderId(record.id); setShowHistory(false); setShowBill(false); setQrSrc('');
                window.scrollTo(0,0);
            };

            const handleImportImage = (e) => {
                const file = e.target.files[0];
                if(!file) return;
                const reader = new FileReader();
                reader.onload = (event) => {
                    const img = new Image();
                    img.onload = () => {
                        const canvas = document.createElement('canvas');
                        const ctx = canvas.getContext('2d', { willReadFrequently: true });
                        let w = img.width; let h = img.height;
                        const maxDim = 1500;
                        if(Math.max(w, h) > maxDim) {
                            const ratio = maxDim / Math.max(w, h);
                            w *= ratio; h *= ratio;
                        }
                        canvas.width = w; canvas.height = h;
                        ctx.drawImage(img, 0, 0, w, h);
                        const imageData = ctx.getImageData(0, 0, w, h);
                        
                        if (typeof jsQR !== "undefined") {
                            const code = jsQR(imageData.data, imageData.width, imageData.height);
                            if (code) {
                                try {
                                    let jsonStr = code.data;
                                    let parsed;
                                    try {
                                        parsed = JSON.parse(jsonStr);
                                    } catch(e1) {
                                        jsonStr = decodeURIComponent(escape(code.data));
                                        parsed = JSON.parse(jsonStr);
                                    }
                                    
                                    const restored = restoreData(parsed);
                                    loadFromHistory({ data: restored, id: Date.now() });
                                    
                                    const isPriceList = Object.keys(restored.stdQtys).length === 0 && !restored.orderer.name && !restored.orderer.isHandwritten && restored.limitedItems.length === 0;
                                    
                                    const importedItems = [];
                                    PRODUCTS_LIST.forEach(p => {
                                        const q = parseInt(restored.stdQtys[p.id]) || 0;
                                        if (q > 0) importedItems.push({ name: p.name, qty: q });
                                    });
                                    restored.limitedItems.forEach(i => importedItems.push({ name: i.name, qty: i.qty }));
                                    restored.sharingItems.forEach(i => importedItems.push({ name: i.name, qty: i.qty }));
                                    
                                    let calcGrandTotal = 0;
                                    const disc = parseInt(restored.discount) || 0;
                                    if(!isPriceList) {
                                        let sub = 0;
                                        PRODUCTS_LIST.forEach(p => {
                                            const q = parseInt(restored.stdQtys[p.id]) || 0;
                                            if(q > 0) sub += restored.stdPrices[p.id] * q;
                                        });
                                        restored.limitedItems.forEach(i => sub += i.price * i.qty);
                                        const shipFee = restored.ship.type === 'free' ? 0 : (parseInt(restored.ship.fee) || 0);
                                        calcGrandTotal = sub + shipFee - disc;
                                    }

                                    setSysMsg({
                                        type: 'import_success',
                                        title: '匯入成功',
                                        text: isPriceList ? '已為您套用圖檔中的「報價設定」。' : '已完美還原客戶資料與訂單明細。',
