                                                    <th className="text-center w-[15%] whitespace-nowrap">單價</th>
                                                    <th className="text-center w-[10%] whitespace-nowrap">數量</th>
                                                    <th className="text-left pl-3 md:pl-6 w-[25%] whitespace-nowrap">小計</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {summary.items.map((i, idx) => (
                                                    <tr key={idx} className="text-black even-row even:bg-slate-100 border-b border-slate-200">
                                                        <td className="text-right py-3 md:py-5 pr-2 md:pr-3 leading-tight font-normal">
                                                            {i.name}
                                                            {i.type === '一般' && jinPrices[i.id] !== undefined && <span className="ml-1 md:ml-2 text-sm md:text-2xl text-slate-500 font-bold whitespace-nowrap">(${jinPrices[i.id]}/斤)</span>}
                                                            {i.type === '分享' && <span className="ml-1 md:ml-2 text-[10px] md:text-sm bg-emerald-100 text-emerald-800 px-1 md:px-2 py-0.5 md:py-1 rounded border border-emerald-300 inline-block font-bold">分享</span>}
                                                            {i.type === '限定' && <span className="ml-1 md:ml-2 text-[10px] md:text-sm bg-sky-100 text-sky-800 px-1 md:px-2 py-0.5 md:py-1 rounded border border-sky-300 inline-block font-bold">限定</span>}
                                                        </td>
                                                        <td className="text-center text-black px-1 md:px-2 font-normal whitespace-nowrap">${i.price}</td>
                                                        <td className="text-center px-1 md:px-2 font-normal whitespace-nowrap">x{i.qty}</td>
                                                        <td className="text-left pl-3 md:pl-6 text-black font-normal whitespace-nowrap">${i.total}</td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                            <tfoot className="border-t-4 md:border-t-8 border-slate-300 bg-white">
                                                <tr className="text-sm md:text-lg font-bold text-slate-500">
                                                    <td rowSpan={footerRowCount} colSpan="2" className="p-3 md:p-6 align-bottom border-r-2 md:border-r-4 border-slate-100">
                                                        <div className="text-slate-900 space-y-1 md:space-y-3 text-left">
                                                            <p className="text-xs md:text-base font-black text-slate-400 tracking-widest border-b border-slate-200 pb-1 mb-1 md:mb-2 inline-block">匯款與聯絡資訊</p>
                                                            <p className="text-lg md:text-3xl font-black leading-tight text-indigo-950">郵局(700) <br/><span className="text-xl md:text-5xl">0191289-0858464</span></p>
                                                            <p className="text-lg md:text-3xl font-black leading-tight mt-1 md:mt-2 text-indigo-950">吳庭葳</p>
                                                            <p className="text-xl md:text-4xl font-black leading-tight text-indigo-950">0910-745-919</p>
                                                        </div>
                                                    </td>
                                                    <td className="pt-4 md:pt-8 text-center whitespace-nowrap text-sm md:text-xl font-bold">商品總計</td>
                                                    <td className="pt-4 md:pt-8 text-left pl-3 md:pl-6 text-black font-black whitespace-nowrap text-lg md:text-3xl">${summary.subtotal}</td>
                                                </tr>
                                                <tr className="text-sm md:text-lg font-bold text-slate-500">
                                                    <td className="text-center whitespace-nowrap pt-1 md:pt-2">運費金額</td>
                                                    <td className="text-left pl-3 md:pl-6 text-black font-black whitespace-nowrap text-lg md:text-3xl pt-1 md:pt-2">+{summary.actualShip}</td>
                                                </tr>
                                                {summary.actualDisc > 0 && (
                                                    <tr className="text-sm md:text-lg font-bold text-amber-500">
                                                        <td className="text-center whitespace-nowrap pt-1 md:pt-2">折讓優惠</td>
                                                        <td className="text-left pl-3 md:pl-6 font-black whitespace-nowrap text-lg md:text-3xl pt-1 md:pt-2">-{summary.actualDisc}</td>
                                                    </tr>
                                                )}
                                                <tr>
                                                    <td className="pt-2 md:pt-4 text-center text-sm md:text-2xl font-black text-slate-500 uppercase tracking-widest whitespace-nowrap">總金額</td>
                                                    <td className="pt-2 md:pt-4 text-left pl-3 md:pl-6 text-3xl md:text-6xl font-black text-red-600 tracking-tighter leading-none whitespace-nowrap">
                                                        ${summary.grandTotal}
                                                    </td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>

                                    {qrSrc && (
                                        <div className="bg-slate-50 p-4 md:p-6 rounded-2xl md:rounded-[2rem] border-2 md:border-4 border-slate-100 mt-4 md:mt-8 flex justify-between items-center">
                                            <div className="text-left flex-1">
                                                <p className="text-[10px] md:text-sm font-black text-slate-400 tracking-[0.2em] md:tracking-[0.3em] uppercase">Wei Wei Seafood</p>
                                                <p className="text-sm md:text-xl font-black text-slate-500 leading-tight mt-1">感謝您的訂購！請截圖保存本畫面。</p>
                                            </div>
                                            <div className="flex flex-col items-center justify-center ml-2 md:ml-4 bg-white p-1 md:p-2 rounded-lg md:rounded-xl border-2 border-slate-200">
                                                <img src={qrSrc} className="w-16 h-16 md:w-32 md:h-32" alt="QR" />
                                                <span className="text-[8px] md:text-[12px] font-bold text-slate-500 mt-1 md:mt-2 whitespace-nowrap">掃碼快速匯入</span>
                                            </div>
                                        </div>
                                    )}
                                </div>
                            </div>

                            <div className="p-4 md:p-6 bg-slate-100 flex flex-col md:flex-row gap-3 md:gap-6 no-print pb-28 md:pb-32">
                                <button id="btn-screenshot" onClick={handleScreenshot} className="flex-1 bg-emerald-600 text-white py-4 md:py-6 rounded-2xl md:rounded-3xl font-black text-lg md:text-2xl shadow-lg hover:bg-emerald-500 transition-all flex items-center justify-center gap-2 md:gap-3 active:scale-95">
                                    <Icons.Camera /> 彩色圖檔 (傳LINE用)
                                </button>
                                <button id="btn-thermal" onClick={handleThermalPrint} className="flex-1 bg-slate-800 text-white py-4 md:py-6 rounded-2xl md:rounded-3xl font-black text-lg md:text-2xl shadow-lg hover:bg-black transition-all flex items-center justify-center gap-2 md:gap-3 active:scale-95">
                                    <Icons.Receipt /> 貼紙圖檔 (精臣用)
                                </button>
                                <button onClick={()=>setConfirmAction({type: 'next'})} className="flex-1 bg-sky-700 text-white py-4 md:py-6 rounded-2xl md:rounded-3xl font-black text-lg md:text-2xl shadow-lg hover:bg-sky-600 transition-all flex items-center justify-center gap-2 md:gap-3 active:scale-95">
                                    <Icons.Plus /> 下一張訂單
                                </button>
                                <button onClick={()=>setShowBill(false)} className="flex-1 bg-slate-300 text-slate-700 py-4 md:py-6 rounded-2xl md:rounded-3xl font-black text-lg md:text-2xl shadow-xl active:bg-slate-400 transition-all flex items-center justify-center gap-2 md:gap-3">
                                    <Icons.ChevronLeft /> 返回修改
                                </button>
                            </div>
                        </div>
                    )}

                    {/* 底部導覽列 */}
                    {!showBill && (
                        <>
                            <div className="fixed bottom-0 left-0 right-0 bg-slate-900 text-white shadow-[0_-10px_40px_rgba(0,0,0,0.3)] z-40 border-t-4 md:border-t-8 border-sky-600 no-print flex flex-col">
                                <div className="flex border-b border-slate-700 text-xs md:text-base">
                                    <div className="flex-1 flex items-center border-r border-slate-700 p-2 md:p-3">
                                        <span className="font-bold text-slate-400 mr-1 md:mr-2 whitespace-nowrap">🚚 運費</span>
                                        <div className="flex gap-1 md:gap-2 w-full max-w-[120px] md:max-w-[200px]">
                                            <button onClick={()=>setShip({type:'free', fee:''})} className={`flex-1 py-1.5 md:py-2 rounded font-bold ${ship.type==='free'?'bg-sky-600 text-white':'bg-slate-800 text-slate-400'}`}>免運</button>
                                            <button onClick={()=>setShip({type:'paid', fee:ship.fee})} className={`flex-1 py-1.5 md:py-2 rounded font-bold ${ship.type==='paid'?'bg-sky-600 text-white':'bg-slate-800 text-slate-400'}`}>自訂</button>
                                        </div>
                                        {ship.type==='paid' && <input type="number" placeholder="$" className="w-12 md:w-16 ml-1 md:ml-2 p-1 md:p-2 rounded bg-slate-800 text-white text-center font-bold outline-none border border-slate-600 footer-input" value={ship.fee} onChange={e=>setShip({...ship, fee:e.target.value})} />}
                                    </div>
                                    <div className="flex-1 flex items-center p-2 md:p-3">
                                        <span className="font-bold text-slate-400 mr-1 md:mr-2 whitespace-nowrap">🏷️ 折讓</span>
                                        <input type="number" placeholder="輸入金額" className="w-full min-w-[60px] p-1.5 md:p-2 rounded bg-slate-800 text-amber-400 font-bold outline-none border border-slate-600 footer-input" value={discount} onChange={e=>setDiscount(e.target.value)} />
                                    </div>
                                </div>

                                <div className="flex items-center p-2 md:p-4 gap-2 md:gap-4">
                                    <button onClick={() => setShowDetailDrawer(!showDetailDrawer)} className="flex items-center justify-center gap-1 md:gap-2 bg-slate-700 hover:bg-slate-600 px-3 md:px-6 py-2 md:py-4 rounded-xl md:rounded-2xl transition-all shadow-lg active:scale-95">
                                        {showDetailDrawer ? <Icons.ChevronLeft /> : <Icons.List />}
                                        <span className="font-bold text-sm md:text-lg hidden xs:inline">明細</span>
                                    </button>
                                    
                                    <button onClick={submit} className="flex-1 flex items-center justify-center gap-1 md:gap-2 bg-emerald-500 hover:bg-emerald-400 text-white px-3 md:px-6 py-3 md:py-4 rounded-xl md:rounded-2xl shadow-lg transition-all active:scale-95">
                                        <Icons.Check />
                                        <span className="font-black text-lg md:text-2xl tracking-widest whitespace-nowrap">產出訂單</span>
                                    </button>

                                    <div className="flex flex-col items-end min-w-[80px] md:min-w-[120px]">
                                        <span className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest">Total</span>
                                        <span className="text-2xl md:text-5xl font-black text-white tracking-tighter leading-none">${summary.grandTotal}</span>
                                    </div>
                                </div>
                            </div>

                            {/* 側邊明細抽屜 */}
                            <div className={`fixed top-0 left-0 h-full w-72 md:w-80 max-w-[85%] bg-white shadow-2xl z-50 drawer-transition ${showDetailDrawer ? 'translate-x-0' : '-translate-x-full'}`}>
                                <div className="p-3 md:p-4 bg-slate-800 text-white font-black text-lg md:text-xl flex justify-between items-center">
                                    <span>📝 已選明細</span>
                                    <button onClick={()=>setShowDetailDrawer(false)}><Icons.ChevronLeft /></button>
                                </div>
                                <div className="overflow-y-auto p-3 md:p-4 space-y-2 md:space-y-3 h-[calc(100%-60px)]">
                                    {summary.items.length === 0 ? (
                                        <p className="text-center text-slate-400 py-8 text-sm">尚未選擇任何商品</p>
                                    ) : (
                                        summary.items.map((item, idx) => (
                                            <div key={idx} className="flex justify-between items-center py-2 md:py-3 border-b border-slate-100 last:border-0">
                                                <div className="flex-1 pr-2 overflow-hidden">
                                                    <div className="font-medium text-slate-800 text-base md:text-xl truncate">
                                                        {item.name} 
                                                        {item.type === '分享' && <span className="ml-1 md:ml-2 text-[10px] md:text-xs bg-emerald-100 text-emerald-700 px-1 md:px-2 py-0.5 rounded font-bold">分享</span>}
                                                    </div>
                                                    <div className="text-xs md:text-sm text-slate-400 mt-0.5 md:mt-1">
                                                        ${item.price} x {item.qty}
                                                    </div>
                                                </div>
                                                <div className="font-black text-lg md:text-2xl text-slate-800">
                                                    ${item.total}
                                                </div>
                                            </div>
                                        ))
                                    )}
                                    <div className="pt-3 md:pt-4 mt-3 md:mt-4 border-t-2 border-slate-100 space-y-1 md:space-y-2 text-sm md:text-base">
                                        <div className="flex justify-between items-center">
                                            <span className="font-bold text-slate-500">小計</span>
                                            <span className="font-black text-lg md:text-xl text-slate-800">${summary.subtotal}</span>
                                        </div>
                                        <div className="flex justify-between items-center">
                                            <span className="font-bold text-slate-500">運費</span>
                                            <span className="font-black text-lg md:text-xl text-slate-800">+${summary.actualShip}</span>
                                        </div>
                                        {summary.actualDisc > 0 && (
                                            <div className="flex justify-between items-center text-amber-600">
                                                <span className="font-bold">折讓</span>
                                                <span className="font-black text-lg md:text-xl">-${summary.actualDisc}</span>
                                            </div>
                                        )}
                                        <div className="flex justify-between items-center pt-2 border-t border-slate-200">
                                            <span className="font-black text-base md:text-lg text-slate-800">應付總額</span>
                                            <span className="font-black text-2xl md:text-3xl text-red-600">${summary.grandTotal}</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            {showDetailDrawer && (
                                <div className="fixed inset-0 bg-black/50 z-40" onClick={()=>setShowDetailDrawer(false)}></div>
                            )}
                        </>
                    )}
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>


