                const savedId = saveToHistory(orderData);
                setCurrentOrderId(savedId);
                
                if (typeof QRious !== "undefined") {
                    try {
                        const minData = minifyData(orderData);
                        const jsonStr = JSON.stringify(minData);
                        const utf8Str = unescape(encodeURIComponent(jsonStr)); 
                        const qr = new QRious({ value: utf8Str, size: 400, level: 'M' });
