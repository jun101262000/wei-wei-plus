            const summary = useMemo(() => {
                const items = [];
                PRODUCTS_LIST.forEach(p => {
                    const q = parseInt(stdQtys[p.id]) || 0;
                    if (q > 0) items.push({ id: p.id, name: p.name, price: stdPrices[p.id], qty: q, total: stdPrices[p.id] * q, type: '一般' });
