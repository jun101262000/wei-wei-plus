                            setSysMsg({ type: 'error', title: '系統錯誤', text: '系統元件載入中，請稍後再試。' });
                        }
                    };
                    img.src = event.target.result;
                };
                reader.readAsDataURL(file);
                e.target.value = ''; 
            };

            const deleteHistoryItem = (id) => {
                const newHistory = history.filter(h => h.id !== id);
